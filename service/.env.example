# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Secret used to authenticate requests (Authorization: Bearer <key>)
API_KEY=your-secret-api-key-here

# goNEON creditor details — embedded in every payment slip
CREDITOR_NAME=goNEON GmbH
CREDITOR_STREET=Musterstrasse 1
CREDITOR_PLZ=8001
CREDITOR_CITY=Zürich
CREDITOR_COUNTRY=CH

# ── OPTIONAL ───────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override in Railway
# PORT=3000
