{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd service && npm ci --omit=dev",
    "watchPatterns": ["service/**"]
  },
  "deploy": {
    "startCommand": "cd service && node src/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
